{
  "env": {
    "AGENTIHOOKS_SECRETS_MODE": "strict"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(git push * dev*)",
      "Bash(git push * develop*)",
      "Bash(git push * staging*)",
      "Bash(git push * production*)",
      "Bash(git push *:main*)",
      "Bash(git push *:master*)",
      "Bash(git push *:dev*)",
      "Bash(git push *:develop*)",
      "Bash(git push *:staging*)",
      "Bash(git push *:production*)",
      "Bash(git push *--force*)",
      "Bash(git merge*)",
      "Bash(gh *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Bash(docker *)",
      "Bash(kubectl *)"
    ]
  }
}
