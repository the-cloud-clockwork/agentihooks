{
  "env": {
    "AGENTIHOOKS_SECRETS_MODE": "standard",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "defaultMode": "default",
    "ask": [
      "Bash(git reset --hard*)",
      "Bash(git checkout -- *)",
      "Bash(rm -rf *)",
      "Bash(docker rm *)",
      "Bash(docker stop *)",
      "Bash(kubectl delete *)"
    ]
  }
}
