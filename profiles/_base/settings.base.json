{
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Task(*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cd /app && __PYTHON__ -m hooks.statusline"
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "hooks": {
    "SessionStart":      [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "SessionEnd":        [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "PreToolUse":        [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "PostToolUse":       [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "Stop":              [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "SubagentStop":      [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "UserPromptSubmit":  [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "Notification":      [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "PreCompact":        [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}],
    "PermissionRequest": [{"hooks": [{"type": "command", "command": "cd /app && __PYTHON__ -m hooks"}]}]
  }
}
