# AgentiHooks — User Environment File
# =====================================
# This file is seeded to ~/.agentihooks/.env on first install.
# Values here OVERRIDE the shell session environment for hooks-utils and
# lifecycle hooks. Edit ~/.agentihooks/.env — never edit this file directly.
#
# Shell tip: to expose these vars to ALL MCP servers (not just hooks-utils),
# add the following to ~/.bashrc or ~/.zshrc:
#   [ -f ~/.agentihooks/.env ] && set -a && . ~/.agentihooks/.env && set +a

# =============================================================================
# RUNTIME DATA ROOT
# =============================================================================
# Override the default ~/.agentihooks directory (e.g. for K8s shared mounts).
# AGENTIHOOKS_HOME=/mnt/efs/shared

# =============================================================================
# HOOK LOGGING
# =============================================================================
# CLAUDE_HOOK_LOG_ENABLED=true
# CLAUDE_HOOK_LOG_FILE=~/.agentihooks/logs/hooks.log
# AGENT_LOG_FILE=~/.agentihooks/logs/agent.log
# LOG_HOOKS_COMMANDS=false
# LOG_TRANSCRIPT=true
# STREAM_AGENT_LOG=true
# LOG_USE_COLORS=true

# =============================================================================
# MEMORY
# =============================================================================
# MEMORY_AUTO_SAVE=true

# =============================================================================
# SECRETS SCANNING
# =============================================================================
# Controls how secrets scanning behaves: off | warn | standard | strict
# AGENTIHOOKS_SECRETS_MODE=standard

# =============================================================================
# MCP TOOL SERVER
# =============================================================================
# MCP_CATEGORIES=all
# ALLOWED_TOOLS=

# =============================================================================
# INTEGRATIONS
# =============================================================================

# --- GitHub ---
# App-based auth (preferred for orgs):
# GITHUB_APP_ID=
# GITHUB_INSTALLATION_ID=
# GITHUB_SECRET_ID=
# GITHUB_API_BASE=https://api.github.com
# Direct token auth:
# GITHUB_TOKEN=

# --- Confluence ---
# CONFLUENCE_SERVER_URL=https://your-org.atlassian.net
# CONFLUENCE_TOKEN=
# CONFLUENCE_SPACE_KEY=
# PARENT_PAGE_ID=

# --- Email (SMTP) ---
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SENDER_EMAIL=
# SMTP_SERVER_IP=   # optional fallback IP

# --- AWS (SQS, S3, Lambda, DynamoDB) ---
# AWS_REGION=us-east-1
# SQS_QUEUE_URL=
# STORAGE_URL=s3://your-bucket
# DYNAMODB_TABLE_NAME=
# DYNAMODB_PARTITION_KEY=session_id
# DYNAMODB_SORT_KEY=
# LAMBDA_FUNCTION_NAME=
# LAMBDA_INVOCATION_TYPE=RequestResponse

# --- Webhook ---
# WEBHOOK_URL=
# WEBHOOK_AUTH_HEADER=X-Auth-Token
# WEBHOOK_AUTH_TOKEN=
# WEBHOOK_TIMEOUT=30

# --- PostgreSQL ---
# POSTGRES_HOST=
# POSTGRES_NAME=
# POSTGRES_USERNAME=
# POSTGRES_PASSWORD=
# POSTGRES_PORT=5432
# POSTGRES_TABLE=

# --- Completions / Agent API ---
# AGENT_API_ENDPOINT=http://localhost:8000
# AGENT_API_KEY=
# AGENT_API_TIMEOUT=300

# =============================================================================
# TOKEN CONTROL
# =============================================================================
# Master switch — set false to disable all token control features
# TOKEN_CONTROL_ENABLED=true

# Context window monitor (StatusLine integration)
# TOKEN_MONITOR_ENABLED=true
# TOKEN_WARN_PCT=60
# TOKEN_CRITICAL_PCT=80
# TOKEN_REDIS_TTL=3600

# Bash output truncation (reduces verbose command output in context)
# BASH_FILTER_ENABLED=true
# BASH_FILTER_MAX_LINES=50
# BASH_FILTER_MAX_CHARS=5000
# BASH_FILTER_TEST_MAX_FAILURES=10
# BASH_FILTER_GIT_MAX_COMMITS=20

# File read deduplication (blocks redundant re-reads within a session)
# FILE_READ_CACHE_ENABLED=true
# FILE_READ_CACHE_BACKEND=redis
# FILE_READ_CACHE_TTL=21600

# MCP hygiene reminder at session start
# MCP_HYGIENE_ENABLED=true

# =============================================================================
# CONSOLE QUOTA DISPLAY  (opt-in — requires scripts/claude_usage_watcher.py)
# =============================================================================
# Path where the watcher writes quota JSON (and statusline reads it from)
# CLAUDE_USAGE_FILE=~/.agentihooks/claude_usage.json
# Seconds before data is considered stale (default: 5 minutes)
# CLAUDE_USAGE_STALE_SEC=300
# Watcher poll interval in seconds (default: 60)
# CLAUDE_USAGE_POLL_SEC=60

# =============================================================================
# MEMORY MIRROR (opt-in — cross-machine auto-memory sync, PR-gated)
# =============================================================================
# Mirrors ONLY ~/.claude/projects/*/memory/** (transcripts and sessions excluded).
# Every machine pushes to gitfoam/<hostname>/main and pulls FROM origin/main only;
# promotion to main is a PR via `agentihooks memory-sync propose`.
# Enable, set a private git remote, then run:   agentihooks memory-sync install
#
# MEMORY_MIRROR_ROLE (v4 — preferred):
#   off          dormant (default)
#   consumer     fetch + consume main only (no push; read-only pod)
#   offline      snapshot + gitfoam push only (no fetch/merge; air-gapped)
#   contributor  v3 behavior: snapshot + push + fetch + merge; promote via `propose`
#   authority    single-leader: contributor pipeline + direct force-with-lease
#                push to origin/main. EXACTLY ONE authority per fleet.
# MEMORY_MIRROR_ROLE=contributor
#
# MEMORY_MIRROR_MODE (v3 legacy, still honored when ROLE is unset):
#   off | write | write-local-only
# Derivation: write→contributor, write-local-only→offline, off→off.
# Back-compat: legacy MEMORY_MIRROR_ENABLED=true maps to contributor.
# MEMORY_MIRROR_MODE=write
# MEMORY_MIRROR_REMOTE=git@github.com:YOUR-ORG/claude-memory-mirror.git
# MEMORY_MIRROR_DIR=~/.agentihooks/memory-mirror
# MEMORY_MIRROR_BRANCH_PREFIX=gitfoam
# MEMORY_MIRROR_INTERVAL_SEC=60
# MEMORY_MIRROR_SWEEP_IDLE_DAYS=15
# MEMORY_MIRROR_CLAUDE_PROJECTS=~/.claude/projects
# GITFOAM_BINARY=~/.cargo/bin/gitfoam
# Local dev path to gitfoam repo (used if the binary is missing and you want to cargo-install from source)
# GITFOAM_LOCAL_SOURCE=/home/iamroot/dev/tcc-ecosystem/gitfoam

# =============================================================================
# BROADCAST SYSTEM — fleet messaging
# =============================================================================
# Severity tiers:
#   info      → once per session (deduped via delivered_to)
#   alert     → every UserPromptSubmit (persistent, ack-only)
#   critical  → every UserPromptSubmit + every PreToolUse (when enabled below)
#
# Defaults (changed 2026-05-05):
#   BROADCAST_CRITICAL_ON_PRETOOL=false   (was true) — gate alerts off PreToolUse
#   BROADCAST_PRETOOL_MIN_SEVERITY=critical (was alert) — only emergencies fire on tool calls
# These defaults reduce hook-error contamination per Claude Code issue #34713.
# Operators on incident response can opt back in:
# BROADCAST_CRITICAL_ON_PRETOOL=true
# BROADCAST_PRETOOL_MIN_SEVERITY=alert
#
# Per-injection byte caps. 0 (default) = no cap — full content ships through
# whatever stdout the hook emits. Set >0 to opt in to truncation when you
# need envelope headroom under Claude Code's 10,000-char hook output limit
# (over → harness silently writes to a temp file and the model receives a
# filepath instead of the body).
#
# Recommended values when you opt in:
#   BROADCAST_MAX_BYTES_PRETOOL=4096   — keeps PreToolUse alerts under 4 KB
#   BROADCAST_MAX_BYTES_PROMPT=8192    — keeps banner injects under 8 KB
#   CI_MANIFESTO_MAX_BYTES=7500        — caps CI manifesto inject + adds a
#                                         "Read full doctrine at <path>" footer
#
# To see what each event currently emits and whether anything is over the
# 10K Claude Code cap:  agentihooks doctor --debug-hook
# BROADCAST_MAX_BYTES_PRETOOL=0
# BROADCAST_MAX_BYTES_PROMPT=0
# CI_MANIFESTO_MAX_BYTES=0
